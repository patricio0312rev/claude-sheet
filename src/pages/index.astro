---
import Layout from '../layouts/Layout.astro';
import { getEntry, render } from 'astro:content';
import CopyButtons from '../components/CopyButtons';
import KeyboardNav from '../components/KeyboardNav';
import ScrollSpy from '../components/ScrollSpy';
import MobileToc from '../components/MobileToc';
import Search from '../components/Search';

const entry = await getEntry('sheet', 'cheat-sheet');
if (!entry) throw new Error('Cheat sheet content not found');
const { Content, headings } = await render(entry);
const tocHeadings = headings
  .filter((h) => h.depth === 2)
  .map((h) => ({ slug: h.slug, text: h.text }));
---

<Layout
  title="clawd — Claude Code Cheat Sheet"
  description="Everything you need in one place — Commands, Shortcuts, Features & Tips for Claude Code"
>
  <!-- Ambient background glow -->
  <div class="fixed inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="absolute -top-[40%] -left-[20%] w-[60%] h-[60%] rounded-full bg-accent/[0.03] blur-[120px]"></div>
    <div class="absolute -bottom-[30%] -right-[10%] w-[50%] h-[50%] rounded-full bg-amber/[0.02] blur-[100px]"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="pt-12 sm:pt-16 pb-8">
      <div class="flex items-center gap-3 mb-6">
        <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-surface border border-border text-xs font-mono text-text-muted">
          <span class="w-2 h-2 rounded-full bg-green animate-pulse"></span>
          v2026
        </div>
      </div>
      <h1 class="font-heading text-3xl sm:text-5xl font-bold text-text tracking-tight leading-[1.1]">
        Claude Code<br />
        <span class="text-accent">Cheat Sheet</span>
      </h1>
      <p class="text-text-secondary mt-4 text-base sm:text-lg max-w-xl leading-relaxed">
        Commands, shortcuts, features & tips — everything you need in one place.
      </p>
    </header>

    <Search client:load />

    <!-- Main content area with sidebar -->
    <div class="lg:grid lg:grid-cols-[220px_1fr] lg:gap-12 pb-12">
      <!-- TOC Sidebar -->
      <aside id="toc-sidebar" class="hidden lg:block">
        <nav class="sticky top-8">
          <h2 class="text-[0.6875rem] uppercase tracking-[0.15em] text-text-muted mb-4 font-medium">
            On this page
          </h2>
          <ul class="space-y-0.5 text-[0.8125rem]">
            {headings.filter((h) => h.depth === 2).map((heading) => (
              <li>
                <a
                  href={`#${heading.slug}`}
                  class="block py-1.5 px-3 rounded-md text-text-muted hover:text-text hover:bg-surface transition-all duration-150 truncate cursor-pointer"
                  data-toc-link
                >
                  {heading.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>

      <!-- Rendered markdown content -->
      <main id="sheet-content" class="prose min-w-0">
        <Content />
      </main>
      <CopyButtons client:load />
      <KeyboardNav client:load />
      <ScrollSpy client:load />
    </div>

    <MobileToc headings={tocHeadings} client:load />

    <!-- Footer -->
    <footer class="border-t border-border py-8 text-center">
      <p class="text-sm text-text-muted">
        Built with
        <a href="https://astro.build" class="text-text-secondary hover:text-accent transition-colors cursor-pointer">Astro</a>
        <span class="mx-1.5 text-border-bright">·</span>
        Source on
        <a href="https://github.com/patricio0312rev/claude-sheet" class="text-text-secondary hover:text-accent transition-colors cursor-pointer">GitHub</a>
      </p>
    </footer>
  </div>
</Layout>

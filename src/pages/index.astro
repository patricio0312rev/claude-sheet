---
import Layout from '../layouts/Layout.astro';
import { getEntry, render } from 'astro:content';
import CopyButtons from '../components/CopyButtons';
import KeyboardNav from '../components/KeyboardNav';
import ScrollSpy from '../components/ScrollSpy';
import MobileToc from '../components/MobileToc';
import SearchModal from '../components/SearchModal';
import HeadingIcons from '../components/HeadingIcons';
import CopyCommands from '../components/CopyCommands';
import ClaudeIcon from '../components/ClaudeIcon';
import ThemeToggle from '../components/ThemeToggle';
import Toast from '../components/Toast';
import StickyHeader from '../components/StickyHeader';
import SheetMode from '../components/SheetMode';

const entry = await getEntry('sheet', 'cheat-sheet');
if (!entry) throw new Error('Cheat sheet content not found');
const { Content, headings } = await render(entry);
const tocHeadings = headings
  .filter((h) => h.depth === 2)
  .map((h) => ({ slug: h.slug, text: h.text }));
---

<Layout
  title="clawd — Claude Code Cheat Sheet"
  description="Everything you need in one place — Commands, Shortcuts, Features & Tips for Claude Code"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="pt-12 sm:pt-20 pb-8 border-b-[3px] border-text mb-10 animate-in">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 pb-2">
        <div>
          <h1 class="font-heading text-5xl sm:text-6xl lg:text-7xl text-text font-extrabold leading-[0.95] tracking-tighter flex items-center gap-3">
            <ClaudeIcon size={48} className="text-accent shrink-0 w-10 h-10 sm:w-12 sm:h-12 lg:w-14 lg:h-14" />
            Claude Code
          </h1>
          <p class="font-mono text-[0.6875rem] text-text-muted tracking-[0.25em] uppercase mt-2">The Complete Cheat Sheet</p>
        </div>
        <div class="flex items-center gap-3">
          <button
            id="header-search-trigger"
            type="button"
            class="flex items-center gap-2 px-3 py-2 text-sm border-b border-text text-text-muted hover:text-text transition-colors cursor-pointer w-full sm:max-w-xs"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
              <circle cx="11" cy="11" r="8" />
              <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
            <span class="flex-1 text-left text-sm">Search commands, shortcuts...</span>
            <kbd class="hidden sm:inline-flex items-center px-1.5 py-0.5 text-[0.625rem] font-mono bg-surface text-text-muted">/</kbd>
          </button>
          <button
            id="header-view-toggle"
            type="button"
            class="flex items-center justify-center w-8 h-8 text-text-muted hover:text-text transition-colors cursor-pointer"
            title="Toggle sheet mode"
            aria-label="Toggle sheet mode"
          >
            <svg id="header-view-icon-grid" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter">
              <rect x="3" y="3" width="7" height="7" />
              <rect x="14" y="3" width="7" height="7" />
              <rect x="3" y="14" width="7" height="7" />
              <rect x="14" y="14" width="7" height="7" />
            </svg>
            <svg id="header-view-icon-list" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter" style="display:none">
              <line x1="3" y1="6" x2="21" y2="6" />
              <line x1="3" y1="12" x2="21" y2="12" />
              <line x1="3" y1="18" x2="21" y2="18" />
            </svg>
          </button>
          <ThemeToggle client:load />
        </div>
      </div>
    </header>

    <!-- Main content area with sidebar -->
    <div class="lg:grid lg:grid-cols-[220px_1fr] lg:gap-12 pb-12 animate-in" style="animation-delay: 80ms">
      <!-- TOC Sidebar -->
      <aside id="toc-sidebar" class="hidden lg:block">
        <nav class="sticky top-8">
          <p class="font-mono text-[0.5625rem] text-text-muted tracking-[0.2em] uppercase mb-3 pl-3">Contents</p>
          <ul class="space-y-0 text-[0.8125rem] border-l border-border">
            {
              headings
                .filter((h) => h.depth === 2)
                .map((heading) => (
                  <li>
                    <a
                      href={`#${heading.slug}`}
                      class="block py-1.5 px-3 -ml-px border-l-2 border-transparent text-text-muted hover:text-text hover:border-border-bright transition-all duration-150 truncate cursor-pointer toc-link"
                      data-toc-link
                    >
                      {heading.text}
                    </a>
                  </li>
                ))
            }
          </ul>
        </nav>
      </aside>

      <!-- Rendered markdown content -->
      <main id="sheet-content" class="prose min-w-0">
        <Content />
      </main>
      <HeadingIcons client:load />
      <CopyButtons client:load />
      <CopyCommands client:load />
      <KeyboardNav client:load />
      <ScrollSpy client:load />
    </div>

    <SheetMode client:load />
    <MobileToc headings={tocHeadings} client:load />
    <Toast client:load />
    <StickyHeader client:load />
    <SearchModal client:load />

    <script is:inline>
      document.getElementById('header-search-trigger')?.addEventListener('click', function() {
        window.dispatchEvent(new Event('open-search'));
      });

      (function() {
        function updateViewIcons(isSheet) {
          var gridIcons = document.querySelectorAll('[id$="view-icon-grid"]');
          var listIcons = document.querySelectorAll('[id$="view-icon-list"]');
          gridIcons.forEach(function(el) { el.style.display = isSheet ? 'none' : 'block'; });
          listIcons.forEach(function(el) { el.style.display = isSheet ? 'block' : 'none'; });
        }

        function toggleViewMode() {
          var html = document.documentElement;
          var isSheet = html.getAttribute('data-view-mode') === 'sheet';
          if (isSheet) {
            html.removeAttribute('data-view-mode');
            localStorage.setItem('viewMode', 'doc');
            window.dispatchEvent(new CustomEvent('view-mode-changed', { detail: 'doc' }));
          } else {
            html.setAttribute('data-view-mode', 'sheet');
            localStorage.setItem('viewMode', 'sheet');
            window.dispatchEvent(new CustomEvent('view-mode-changed', { detail: 'sheet' }));
          }
          updateViewIcons(!isSheet);
        }

        // Initialize icon state
        updateViewIcons(document.documentElement.getAttribute('data-view-mode') === 'sheet');

        // Bind all view toggle buttons
        document.querySelectorAll('[id$="view-toggle"]').forEach(function(btn) {
          btn.addEventListener('click', toggleViewMode);
        });

        // Re-bind when sticky header creates new buttons
        window.addEventListener('view-toggle-mounted', function() {
          document.querySelectorAll('[id$="view-toggle"]').forEach(function(btn) {
            btn.removeEventListener('click', toggleViewMode);
            btn.addEventListener('click', toggleViewMode);
          });
          updateViewIcons(document.documentElement.getAttribute('data-view-mode') === 'sheet');
        });
      })();
    </script>

    <footer class="border-t-[3px] border-text py-8 mt-12 flex items-center justify-between">
      <p class="font-mono text-[0.6875rem] text-text-muted">Made with 💜 by <a href="https://github.com/patricio0312rev" class="text-text-secondary hover:text-accent transition-colors">@patricio0312rev</a></p>
      <a
        href="https://github.com/patricio0312rev/claude-sheet"
        class="font-mono text-[0.6875rem] text-text-muted hover:text-accent transition-colors"
      >GitHub &rarr;</a>
    </footer>
  </div>
</Layout>
